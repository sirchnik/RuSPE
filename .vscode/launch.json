{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PSC3-Secure",
            "type": "cortex-debug",
            "servertype": "openocd",
            "request": "launch",
            "executable": "${workspaceRoot}/target/thumbv8m.main-none-eabi/debug/psc3m5_evk_sec_merged.hex",
            "cwd": "${workspaceRoot}",
            "openOCDLaunchCommands": [
                "init; reset init;"
            ],
            "overrideRestartCommands": [
                "starti"
            ],
            "preLaunchCommands": [
                "add-symbol-file ${workspaceRoot}/target/thumbv8m.main-none-eabi/debug/psc3m5_evk_secure",
                "add-symbol-file ${workspaceRoot}/target/thumbv8m.main-none-eabi/debug/psc3m5_evk"
            ],
            "preLaunchTask": "build.psc3m5_evk",
            "svdFile": "../psc3.svd",
            "configFiles": [
                "${workspaceRoot}/boards/psc3m5_evk/openocd.tcl",
            ],
        },
    ]
}
